# === Elite Drive — орчны хувьсагчийн жишээ ===
# apps/api/.env болон apps/web/.env.local руу хуулж бөглөнө үү.

# --- apps/api ---
# Локал Docker:
DATABASE_URL="postgresql://elite:elite@localhost:5433/elite_drive?schema=public"
# Neon жишээ (direct, pooler-гүй):
# DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx.ap-southeast-1.aws.neon.tech/DBNAME?sslmode=require"
NODE_ENV=development
PORT=4000
WEB_ORIGIN=http://localhost:3000
API_PUBLIC_URL=http://localhost:4000
JWT_ACCESS_SECRET=change_me
JWT_REFRESH_SECRET=change_me
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL_DAYS=30
OTP_TTL_SEC=300
OTP_DEV_MODE=true
MOBICOM_SMS_URL=
MOBICOM_SMS_USER=
MOBICOM_SMS_PASS=
MOBICOM_SMS_FROM=EliteDrive
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Elite Drive <no-reply@elitedrive.mn>"
UPLOAD_DIR=uploads
# Cloudflare R2 (бүгдийг бөглөвөл зураг R2 руу, эс бөгөөс локал диск)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=
# --- apps/web (.env.local) ---
NEXT_PUBLIC_API_URL=http://localhost:4000
