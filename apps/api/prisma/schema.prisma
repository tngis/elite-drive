// Elite Drive — Phase 1 өгөгдлийн загвар (PostgreSQL + Prisma)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BookingStatus {
  pending
  approved
  active
  completed
  cancelled
  rejected
}

enum PaymentMethod {
  bank_transfer
  qpay
  socialpay
  cash
}

enum PaymentStatus {
  pending
  paid
  refunded
}

enum OtpChannel {
  phone
  email
}

model User {
  id        String   @id @default(cuid())
  name      String
  phone     String?  @unique
  email     String?  @unique
  avatarUrl String?
  isAdmin   Boolean  @default(false)
  isBlocked Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cars            Car[]            @relation("OwnerCars")
  bookingsAsRenter Booking[]       @relation("RenterBookings")
  bookingsAsOwner  Booking[]       @relation("OwnerBookings")
  refreshTokens   RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

model OtpCode {
  id          String     @id @default(cuid())
  channel     OtpChannel
  destination String     // утас эсвэл имэйл
  codeHash    String
  expiresAt   DateTime
  consumedAt  DateTime?
  attempts    Int        @default(0)
  createdAt   DateTime   @default(now())

  @@index([destination])
  @@map("otp_codes")
}

model Car {
  id           String       @id @default(cuid())
  ownerId      String
  owner        User         @relation("OwnerCars", fields: [ownerId], references: [id], onDelete: Cascade)
  brand        String
  name         String
  year         Int
  plateNumber  String
  color        String
  category     String
  transmission String
  fuel         String
  seats        Int
  pricePerDay  Int
  deposit      Int          @default(0)
  location     String
  description  String?
  features     String[]     @default([])
  instantBook  Boolean      @default(false)
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  images       CarImage[]
  availability Availability[]
  bookings     Booking[]

  @@index([ownerId])
  @@index([category])
  @@map("cars")
}

model CarImage {
  id        String   @id @default(cuid())
  carId     String
  car       Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
  url       String
  position  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([carId])
  @@map("car_images")
}

// Owner-ийн гар аргаар хаасан боломжгүй огнооны блок
model Availability {
  id        String   @id @default(cuid())
  carId     String
  car       Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
  startDate DateTime @db.Date
  endDate   DateTime @db.Date
  createdAt DateTime @default(now())

  @@index([carId])
  @@map("availability_blocks")
}

model Booking {
  id             String        @id @default(cuid())
  carId          String
  car            Car           @relation(fields: [carId], references: [id], onDelete: Cascade)
  renterId       String
  renter         User          @relation("RenterBookings", fields: [renterId], references: [id])
  ownerId        String
  owner          User          @relation("OwnerBookings", fields: [ownerId], references: [id])
  status         BookingStatus @default(pending)
  startDate      DateTime      @db.Date
  endDate        DateTime      @db.Date
  pickupLocation String?
  note           String?
  decisionReason String?

  // Үнийн агшин дахь хувилбар (snapshot)
  pricePerDay Int
  days        Int
  subtotal    Int
  serviceFee  Int
  deposit     Int
  total       Int

  paymentMethod PaymentMethod
  paymentStatus PaymentStatus @default(pending)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([carId])
  @@index([renterId])
  @@index([ownerId])
  @@index([status])
  @@map("bookings")
}
